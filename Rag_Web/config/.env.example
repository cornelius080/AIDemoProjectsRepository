# =============================================================================
# API Keys Configuration
# =============================================================================
# Duplicate this file as '.env' and fill in the required API keys.
# Do NOT commit your actual '.env' file to version control.

# LangSmith for tracing (Optional, enabled from UI)
LANGSMITH_API_KEY=

# Tavily for Web Search (Required)
TAVILY_API_KEY=

# OpenAI Models
OPENAI_API_KEY=

# Google (Gemini) Models
GOOGLE_API_KEY=

# Anthropic (Claude) Models
ANTHROPIC_API_KEY=

# Ollama Models
OLLAMA_API_KEY=

# HuggingFace
HUGGINGFACE_API_KEY=
